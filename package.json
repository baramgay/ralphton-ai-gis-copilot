{
  "name": "ralphton-ai-gis-copilot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run data:boundaries:validate && next build",
    "start": "next start",
    "data:boundaries": "node scripts/fetch-boundaries.mjs",
    "data:boundaries:validate": "node scripts/validate-boundaries.mjs",
    "data:seed": "node scripts/seed-demo-data.mjs",
    "data:sync": "node scripts/sync-live-data.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "verify:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-windows.ps1",
    "verify": "node scripts/verify.mjs",
    "verify:unit": "npm run test && npm run typecheck && npm run lint && npm run build",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "@supabase/supabase-js": "2.84.0",
    "@turf/area": "7.3.5",
    "@turf/bbox": "7.3.5",
    "@turf/boolean-point-in-polygon": "7.3.5",
    "@turf/boolean-valid": "7.3.5",
    "@turf/buffer": "7.3.5",
    "@turf/centroid": "7.3.5",
    "@turf/distance": "7.3.5",
    "@turf/helpers": "7.3.5",
    "@turf/nearest-point": "7.3.5",
    "@turf/point-on-feature": "7.3.5",
    "@turf/points-within-polygon": "7.3.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "26.1.0",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
