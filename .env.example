DATA_GO_KR_SERVICE_KEY=
DATA_SYNC_SECRET=
# Vercel Cron (optional). Vercel injects Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
# Slack/Discord/webhook URL for failed cron sync (optional)
CRON_ALERT_WEBHOOK=
# Set to 1 to skip population merge during live sync
LIVE_POPULATION_DISABLED=
# Set to 1 (or set QWEN_EMBED_MODEL) to re-rank parse-path RAG with remote embeddings
RAG_REMOTE_EMBED=
QWEN_EMBED_MODEL=

KAKAO_REST_API_KEY=
NEXT_PUBLIC_KAKAO_MAP_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_JSON_FALLBACK_MODEL=qwen3.7-plus
QWEN_PRIMARY_MODEL=qwen3.6-flash
SUPABASE_SERVICE_ROLE_KEY=
